---
layout: null
---
[
  {%- assign pages = site.html_pages | where_exp: "p", "p.title" -%}
  {%- for page in pages -%}
    {%- if page.search == false -%}{%- continue -%}{%- endif -%}
    {
      "title":   {{ page.title | jsonify }},
      "url":     {{ page.url | relative_url | jsonify }},
      "excerpt": {{ page.description | default: page.excerpt | strip_html | normalize_whitespace | truncatewords: 24 | jsonify }},
      "content": {{ page.content | strip_html | normalize_whitespace | jsonify }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]